.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.wrangler
# Environment variables
.env
.env.local
# Wrangler local dev secrets (mirrors wrangler secret put values)
.dev.vars
.env.development
.env.staging
.env.production
.env*.local

# Wrangler local dev cache
.wrangler/
.wrangler/**

# Generated by setup — contains real CF Account ID and Secrets Store ID
wrangler.jsonc

# ─── Plugins ──────────────────────────────────────────────────────────────────
# Installed plugin directories are downloaded by install-plugins.mjs at build
# time and must NOT be committed to the origin repository.
src/plugins/*/

# Auto-generated registry is rebuilt by install-plugins.mjs and ensure-registry.mjs.
# It must not be committed with plugin content — it is recreated from plugins.json.
src/plugins/registry.ts

# Auto-generated plugin API route wiring (rebuilt by install-plugins.mjs).
api/plugin-routes.ts

# Per-plugin npm dependency tracking (gitignored — keeps plugin deps out of package.json).
# Reinstalled automatically by ensure-registry.mjs on every predev/prebuild.
plugin-deps.json