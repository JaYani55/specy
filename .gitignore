# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.wrangler
# Environment variables
.env
.env.local
# Wrangler local dev secrets (mirrors wrangler secret put values)
.dev.vars
.env.development
.env.staging
.env.production
.env*.local

# Wrangler local dev cache
.wrangler/
.wrangler/**

# Generated by setup — contains real CF Account ID and Secrets Store ID
wrangler.jsonc

# ─── Plugins ──────────────────────────────────────────────────────────────────
# Workspace plugin directories are local development/install artifacts and are not committed.
plugins/*/

# Auto-generated registry artifacts are rebuilt from workspace plugins in /plugins.
src/plugins/registry.ts
src/plugins/hooks-registry.ts

# Auto-generated plugin API wiring.
api/plugin-routes.ts
api/plugin-hooks.ts
api/plugin-metadata.ts

# Per-plugin npm dependency tracking (gitignored — keeps plugin deps out of package.json).
# Reinstalled automatically by ensure-registry.mjs on every predev/prebuild.
plugin-deps.json
